# Copie para `.env` (cp example.env .env). Nenhum segredo aqui.

# ── Agente do MAS ─────────────────────────────────────────────────
# Default determinístico. USE_LLM=true faz os nós-agente (Coordinator,
# Researcher, Executor, Evaluator) chamarem o modelo do agente abaixo;
# a injeção de falha continua scriptada (independe do LLM).
# O MAS é AGNÓSTICO DE MODELO: o AGENT_MODEL abaixo é só um exemplo — troque
# por qualquer modelo disponível; o modelo efetivo é gravado no manifesto do run.
USE_LLM=false
AGENT_MODEL=llama3.1:8b                     # exemplo; qualquer modelo serve
AGENT_BASE_URL=http://localhost:11434/v1   # ex.: Ollama (OpenAI-compatible)
AGENT_API_KEY=ollama                       # qualquer valor para endpoints locais

# Parâmetros de LLM (valem para o agente)
LLM_TEMPERATURE=0
LLM_TIMEOUT_SECONDS=30

# Resiliência do agente-LLM (só relevante com USE_LLM=true). Backoff de transporte
# espelhando o shim do juiz (D28): re-tenta 429/5xx/timeout respeitando Retry-After,
# senão exponencial (base × 2^tentativa) com teto. Conexão recusada NÃO re-tenta
# (serviço fora do ar → falha imediata; esperar não resolve). Evita que rate-limit
# do OpenRouter degrade um passo para prosa de template silenciosamente.
AGENT_MAX_RETRIES=5                          # tentativas extras antes de desistir
AGENT_RETRY_BASE_SECONDS=5                   # base do backoff exponencial
AGENT_RETRY_MAX_SECONDS=120                  # teto por espera (evita travar em cota diária)

# Modo estrito para gerar o CORPUS FINAL: se o agente-LLM falhar mesmo após os
# retries (ou responder vazio), o run do cenário FALHA em vez de degradar para
# template — garante que nenhuma trajetória mista entre no corpus. Default off
# (dev/smoke tolerante). Runbook da matriz final:
#   USE_LLM=true USE_LLM_STRICT=true make simulate
USE_LLM_STRICT=false

# Nota: o agente usa SÓ as vars AGENT_*. Setar AGENT_BASE_URL explicitamente
# (não confiar no fallback de env da openai).

# ── Juiz do AgentRx (C6) ──────────────────────────────────────────
# JUDGE_BACKEND escolhe como o modelo do juiz é alcançado:
#   stub    -> veredito determinístico offline (default; smoke sem rede)
#   openai  -> API OpenAI-compatible via JUDGE_BASE_URL (Ollama/vLLM/etc.)
#   copilot -> CLI real do GitHub Copilot (precisa do binário no PATH)
#   codex   -> Codex CLI via `codex exec` (precisa do `codex` instalado+autenticado)
# Backend = qualquer shim em scripts/judge_shims/ (ADR-0011); copilot = CLI real.
# O orquestrador traduz estas vars para AGENT_VERIFY_COPILOT_* do AgentRx;
# nunca setar AGENT_VERIFY_* diretamente.
JUDGE_BACKEND=stub
JUDGE_MODEL=                                 # ex.: gpt-5-mini (copilot) | qwen2.5:14b (openai)
JUDGE_BASE_URL=                              # ex.: http://localhost:11434/v1 (backend openai)
JUDGE_API_KEY=                               # bearer do base_url (qualquer valor em locais)
JUDGE_TIMEOUT_SECONDS=600                    # timeout por chamada ao juiz
JUDGE_TEMPERATURE=0                          # usada pelo shim openai; copilot não expõe

# Backoff do shim openai em rate-limit (HTTP 429) e 5xx — deixa a matriz
# atravessar tiers grátis (ex.: OpenRouter :free) sem babá. Respeita Retry-After.
JUDGE_MAX_RETRIES=5                           # tentativas extras antes de desistir
JUDGE_RETRY_BASE_SECONDS=5                    # base do backoff exponencial
JUDGE_RETRY_MAX_SECONDS=120                   # teto por espera (evita travar em cota diária)

# Backend codex (opcional): auth é do próprio `codex login`. Deixe JUDGE_MODEL
# VAZIO para usar o modelo default do plano — conta ChatGPT rejeita gpt-5-codex.
# JUDGE_CODEX_BIN=codex                        # override do binário
# JUDGE_CODEX_ARGS=                            # flags extras de `codex exec` por versão

# ── Telemetria ────────────────────────────────────────────────────
OTEL_SERVICE_NAME=agentrx-otel-poc
