# Copie para `.env`: cp example.env .env. Guia: docs/operacao.md.

# MAS
USE_LLM=false
USE_LLM_STRICT=false
AGENT_MODEL=llama3.1:8b
AGENT_BASE_URL=http://localhost:11434/v1
AGENT_API_KEY=ollama
MAS_ID=
LLM_TEMPERATURE=0
LLM_TIMEOUT_SECONDS=30
AGENT_MAX_RETRIES=5
AGENT_RETRY_BASE_SECONDS=5
AGENT_RETRY_MAX_SECONDS=120

# Juiz
JUDGE_BACKEND=stub
JUDGE_MODEL=
JUDGE_BASE_URL=
JUDGE_API_KEY=
JUDGE_TIMEOUT_SECONDS=600
JUDGE_TEMPERATURE=0
JUDGE_REPS=3
JUDGE_MAX_RETRIES=5
JUDGE_RETRY_BASE_SECONDS=5
JUDGE_RETRY_MAX_SECONDS=120
# JUDGE_CODEX_BIN=codex
# JUDGE_CODEX_ARGS=

# Telemetria
OTEL_SERVICE_NAME=agentrx-otel-poc
