#!/usr/bin/env python3

from __future__ import annotations

import json
import sys

# Constant verdict: System Failure (9) at step 3. Fixed on purpose — the stub
# proves the pipeline plumbs a verdict end to end, not that it is correct.
_VERDICT = {
    "reason_for_failure": "stub deterministic verdict",
    "failure_case": 9,
    "reason_for_index": "stub deterministic index",
    "index": 3,
}


def main() -> int:
    if "--version" in sys.argv:
        print("judge-stub 1.0.0")
        return 0
    # Drain stdin so the parent's write side never blocks; content is ignored.
    sys.stdin.read()
    print(json.dumps(_VERDICT))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
